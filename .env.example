# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
# Use the NEW key types (Supabase is deprecating anon/service_role keys by end of 2026)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (sb_publishable_…) — replaces the legacy anon key. Safe for browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx

# Secret key (sb_secret_…) — replaces legacy service_role key. SERVER ONLY — never expose to browser.
SUPABASE_SECRET_KEY=sb_secret_xxxx

# ── Paystack ──────────────────────────────────────────────────────────────────
# TODO(step-2.1): add when configuring payment plans
PAYSTACK_SECRET_KEY=sk_live_xxxx                       # SERVER ONLY
# Paystack plan codes — created in Paystack dashboard, stored here not in DB
PAYSTACK_PLAN_PERSONAL_MONTHLY=PLN_xxxx
PAYSTACK_PLAN_PERSONAL_ANNUAL=PLN_xxxx
PAYSTACK_PLAN_TEAM_MONTHLY=PLN_xxxx
PAYSTACK_PLAN_TEAM_ANNUAL=PLN_xxxx

# ── Resend ────────────────────────────────────────────────────────────────────
# TODO(step-3.x): add when configuring email
RESEND_API_KEY=re_xxxx                                 # SERVER ONLY
