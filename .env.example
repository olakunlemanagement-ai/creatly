# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
# Use the NEW key types (Supabase is deprecating anon/service_role keys by end of 2026)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (sb_publishable_…) — replaces the legacy anon key. Safe for browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx

# Secret key (sb_secret_…) — replaces legacy service_role key. SERVER ONLY — never expose to browser.
SUPABASE_SECRET_KEY=sb_secret_xxxx

# ── Paystack ──────────────────────────────────────────────────────────────────
# BLOCKER: obtain from Paystack Dashboard → Settings → API Keys
# Without these, Paystack calls are stubbed. See BLOCKERS.md for activation steps.
PAYSTACK_SECRET_KEY=sk_test_xxxx                       # SERVER ONLY — never expose to browser
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxx           # Safe for browser

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000              # https://joincreatly.com in production

# ── Resend ────────────────────────────────────────────────────────────────────
# TODO(step-3.x): add when configuring email
RESEND_API_KEY=re_xxxx                                 # SERVER ONLY

# Creator flags
CREATOR_AUTO_APPROVE=true
